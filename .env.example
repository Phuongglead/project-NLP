GOOGLE_GEMINI_API_KEY=
# Comma-separated pool for batch eval key rotation on 429 quota
GEMINI_API_KEYS=
# xAI Grok fallback when Gemini quota is exhausted
GROK_API_KEY=
SA_AQG_USE_STUBS=false
REVIEW_MODE=false
CORS_ALLOW_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
